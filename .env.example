# PitchSignal - Environment Variables
# Copy to .env and fill in values

# === Server ===
PORT=5099
NODE_ENV=production
# Persistent volume mount point. In Railway, set this + attach a volume at the same path.
# The application stores SQLite (WAL), snapshots and runtime JSON below this directory.
DATA_PATH=/usr/src/app/data
# Override DB path (default: ${DATA_PATH}/predictions.db)
# DB_PATH=

# === CORS ===
# Comma-separated allowed origins (default: localhost:5099, 127.0.0.1:5099)
# CORS_ORIGINS=https://your-domain.com

# === Rate Limiting ===
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=100

# === External APIs ===
# ESPN API (free, no key needed)
# Odds API - https://the-odds-api.com
# Primary key used by PredictionService.fetchExternalOdds and odds collectors.
THE_ODDS_API_KEY=
# Legacy alias still accepted by older odds routes/jobs.
# ODDS_API_KEY=
# OpenWeatherMap - https://openweathermap.org/api
OWM_API_KEY=
# balldontlie - https://www.balldontlie.io (optional roster/stats enrichment)
BALLDONTLIE_API_KEY=
# Tavily search - https://tavily.com (optional, used by AI post-match research)
TAVILY_API_KEY=

# P4-2 squad market value signal. Default off until compareBaseline accepts it.
MARKET_VALUE_SIGNAL_ENABLED=false
# Optional local JSON export path. Defaults to data/market-values.json when enabled.
# MARKET_VALUES_PATH=

# P4-3 continental strength signal. Default off until compareBaseline accepts it.
CONTINENTAL_STRENGTH_SIGNAL_ENABLED=false

# === PWA Goal Push (required together to enable browser push) ===
# Generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Must be a mailto: or https: URI identifying the sender.
VAPID_SUBJECT=mailto:ops@pitchsignal.app

# === Translation (optional; team-name / content i18n) ===
# Leave unset to disable translation calls (falls back to source text).
TRANSLATE_API_URL=
TRANSLATE_API_KEY=
TRANSLATE_MODEL=

# === AI Models (for post-match review) ===
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
CLAUDE_POSTMORTEM_MODEL=deepseek-v4-pro
# DeepSeek key shared by post-match review and Bot.
ANTHROPIC_API_KEY=
# Bot has no provider/model fallback and always calls deepseek-v4-flash.

# === Feature Gates (Beta: all OFF) ===
# NOTE: server.js force-overrides all three to 'false' at startup during the
# public Beta. Setting any to 'true' logs a warning and is ignored until the
# corresponding feature is wired and OOS-validated. (See assertFeatureGates.)
# Polymarket fusion - DO NOT enable until real API integration (Phase 3)
POLYMARKET_ENABLED=false
# Pundit aggregator - DO NOT enable until math validated
PUNDIT_ENABLED=false
# Auto-calibration - DO NOT enable until shadow mode validated
AUTO_CALIBRATION=false
# AI post-match review background worker - Beta default OFF.
# Leave false unless you intentionally want the server to call the AI provider
# and write completed post-match reviews from ready_for_ai rows.
AI_POSTMORTEM_ENABLED=false

# === Security (Beta: ALL THREE must be UNSET/empty) ===
# Token fallback chain:
#   Bot endpoint    → BOT_API_TOKEN || ADMIN_TOKEN
#   Write endpoints → WRITE_API_TOKEN || ADMIN_TOKEN
# Public Beta: leave all three unset → anonymous write → 403
# After Beta: set at least one to re-enable protected endpoints
ADMIN_TOKEN=
BOT_API_TOKEN=
WRITE_API_TOKEN=
# Generate a value with: openssl rand -hex 16

# === Scheduler (optional overrides) ===
# PRE_SNAPSHOT_MINUTES=30
# GROUP_POST_MINUTES=120
# KNOCKOUT_POST_MINUTES=180
# ANALYSIS_DELAY_MINUTES=10
