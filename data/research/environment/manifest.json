  "variables": {
    "alt":  { "unit": "m",    "symmetry": "beta_alt*(A_i - A_opp)" },
    "wbgt": { "unit": "degC", "symmetry": "beta_heat*(H_i - H_opp)" },
    "turf": { "unit": "0/1",  "symmetry": "beta_turf*(S_i - S_opp)" },
    "travel":{ "unit": "km",  "symmetry": "beta_travel*(T_i - T_opp)" },
    "tz":   { "unit": "h",    "symmetry": "beta_tz*(Z_i - Z_opp)" },
    "rest": { "unit": "d",    "symmetry": "beta_rest*(R_i - R_opp)" },
    "et":   { "unit": "min",  "symmetry": "beta_et*(ET_i - ET_opp)" }
  },
  "missing_mechanism": "structural (historical editions have no env fields); missing != neutral; mark missing_reason; degrade to base model pre-1960s; non-random missingness only as feature after OOS proof",
  "file_boundary": "only docs/research/environment-*, data/research/environment-*, scripts/research-environment-*; never lib/prediction.js or public API"
